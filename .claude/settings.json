{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git add .claude/*)"
    ]
  },
  "enabledPlugins": {
    "humwork@claude-community": true,
    "openregistry@claude-community": true,
    "markgrab@claude-community": true,
    "claude-career-plugin@claude-community": true,
    "career-brand@claude-community": true,
    "jobpilot@claude-community": true
  },
  "extraKnownMarketplaces": {
    "claude-community": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-community"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude plugin install humwork@claude-community openregistry@claude-community markgrab@claude-community claude-career-plugin@claude-community career-brand@claude-community jobpilot@claude-community --scope project >/dev/null 2>&1 || true"
          }
        ]
      }
    ]
  }
}
